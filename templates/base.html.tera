<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>wasd.dk - {% block title %}{% endblock title %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      /* Theme variables for light/dark modes */
      :root[data-bs-theme="light"] {
        --bs-body-bg: #f8fafc;
        --bs-body-color: #0f172a;
        --brand-color: #0d6efd;
        --accent-color: #0dcaf0;
        --card-bg: #ffffff;
        --card-border: #e6eefc;
        --muted: #6b7280;
      }
      :root[data-bs-theme="dark"] {
        --bs-body-bg: #071225;
        --bs-body-color: #e6eef8;
        --brand-color: #66b2ff;
        --accent-color: #3ddbd9;
        --card-bg: #0b1226;
        --card-border: #1f2937;
        --muted: #9ca3af;
      }

      body {
        background: var(--bs-body-bg);
        color: var(--bs-body-color);
      }

      img {
        width: 100%;
        border-radius: 8px;
      }

      a { color: var(--brand-color); }

      .navbar {
        background: transparent;
      }

      .navbar-brand { color: var(--brand-color) !important; }
      
      .card { background: var(--card-bg); border: 1px solid var(--card-border); }

      .page-content img { max-width: 100%; height: auto; }

      .list-group-item-action { color: var(--bs-body-color); }
      .list-group-item-action:hover { background: rgba(0,0,0,0.04); }

      .btn-outline-secondary { border-color: rgba(0,0,0,0.08); }
    </style>
    <script>
      // Immediately set theme to avoid flash. Preference: localStorage -> prefers-color-scheme -> light
      (function(){
        try {
          const stored = localStorage.getItem('theme');
          if (stored === 'dark' || stored === 'light') {
            document.documentElement.setAttribute('data-bs-theme', stored);
          } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-bs-theme', 'light');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <nav class="navbar navbar-expand-xl bg-body-tertiary mb-4">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/">wasd</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNavbar"
          aria-controls="mainNavbar"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Your IP
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/ip">Raw text</a></li>
            <li><a class="dropdown-item" href="#" id="remote-ip-value">Loading...</a></li>
          </ul>
        </li>
            <li class="nav-item"><a class="nav-link" href="/pages">All pages</a></li>
            <li class="nav-item"><a class="nav-link" href="https://hosted.fair-it.dk/owa/">Webmail</a></li>
            <li class="nav-item d-none" id="calendar-nav-item"><a class="nav-link" href="/calendar">Kalender</a></li>
          </ul>
          <div class="d-flex align-items-center">
            <a href="/admin"><button class="btn btn-outline-secondary btn-sm me-2" aria-label="Outlink">Admin</button></a>
            <button id="theme-toggle" class="btn btn-outline-secondary btn-sm me-2" aria-label="Toggle theme">Toggle theme</button>
          </div>
        </div>
      </div>
    </nav>

    <div class="container">
      <div class="row">
        <main class="{% block main_class %}col-lg-8{% endblock main_class %} mb-4">
          <div class="card p-4">
            {% block content %}{% endblock content %}
          </div>
        </main>
        {% block sidebar %}
        <aside class="col-lg-4">
          <div class="card p-3">
            <h5 class="mb-3">Lastest edits</h5>
            <div class="list-group">
            <ul class="list-group">
              {% for p in pages | slice(end=10) %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <a class="link" href="/page/{{ p.slug }}">{{ p.title }}</a>
            <span class="badge text-bg-dark rounded-pill"><a href="{% if p.slug | category == '/' %}/page/{% else %}/page{{ p.slug | category }}{% endif %}">{{ p.slug | category }}</a></span>
              </li>
              {% endfor %}
              </ul>
            </div>
          </div>
        </aside>
        {% endblock sidebar %}
      </div>
      <div class="container">
      <p class="fs-6 fw-light text-center fixed-bottom">wasd.dk - &copy; 1998 - 2026</p>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Theme toggle button + persist preference
      (function(){
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function current() { return document.documentElement.getAttribute('data-bs-theme') || 'light'; }
        function setTheme(t) { document.documentElement.setAttribute('data-bs-theme', t); }
        btn.addEventListener('click', function(){
          const next = current() === 'dark' ? 'light' : 'dark';
          try { localStorage.setItem('theme', next); } catch(e) {}
          setTheme(next);
        });
        // update button text
        const observer = new MutationObserver(()=>{ btn.textContent = current() === 'dark' ? 'Switch to light' : 'Switch to dark'; });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        // set initial label
        btn.textContent = current() === 'dark' ? '🔆' : '🌙';
      })();

      // Resolve remote IP from existing /ip route for all pages using base template.
      (function(){
        const ipEl = document.getElementById('remote-ip-value');
        if (!ipEl) return;
        fetch('/ip')
          .then(r => r.ok ? r.text() : Promise.reject(new Error('ip fetch failed')))
          .then(t => {
            const ip = (t || '').trim();
            ipEl.textContent = ip || 'Unknown';
          })
          .catch(() => {
            ipEl.textContent = 'Unknown';
          });
      })();

      // Show calendar link when the current request has calendar access.
      (function(){
        const navItem = document.getElementById('calendar-nav-item');
        if (!navItem) return;
        fetch('/api/calendar/access')
          .then(r => r.ok ? r.json() : Promise.reject(new Error('calendar access failed')))
          .then(data => {
            if (data && data.allowed === true) {
              navItem.classList.remove('d-none');
            }
          })
          .catch(() => {
            // Keep hidden on failure.
          });
      })();
    </script>
  </body>
</html>
